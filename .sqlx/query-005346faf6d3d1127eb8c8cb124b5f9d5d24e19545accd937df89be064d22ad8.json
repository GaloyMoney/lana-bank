  "query": "WITH entities AS (SELECT id FROM core_notes WHERE target_type = $1 AND deleted = FALSE) SELECT i.id AS \"entity_id: Repo__Id\", e.sequence, e.event, CASE WHEN $2 THEN e.context ELSE NULL::jsonb END as \"context: es_entity::ContextData\", e.recorded_at FROM entities i JOIN core_note_events e ON i.id = e.id ORDER BY i.id, e.sequence",
