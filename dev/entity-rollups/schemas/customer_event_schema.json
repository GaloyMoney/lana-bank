{
  "$defs": {
    "Activity": {
      "enum": [
        "inactive",
        "active",
        "suspended"
      ],
      "type": "string"
    },
    "CustomerStatus": {
      "enum": [
        "active",
        "frozen",
        "closed"
      ],
      "type": "string"
    },
    "CustomerType": {
      "enum": [
        "Individual",
        "GovernmentEntity",
        "PrivateCompany",
        "Bank",
        "FinancialInstitution",
        "ForeignAgencyOrSubsidiary",
        "NonDomiciledCompany"
      ],
      "type": "string"
    },
    "KycLevel": {
      "enum": [
        "NotKyced",
        "Basic",
        "Advanced"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "properties": {
        "activity": {
          "$ref": "#/$defs/Activity"
        },
        "applicant_id": {
          "type": ["string", "null"]
        },
        "customer_type": {
          "$ref": "#/$defs/CustomerType"
        },
        "id": {
          "format": "uuid",
          "type": "string"
        },
        "level": {
          "$ref": "#/$defs/KycLevel"
        },
        "party_id": {
          "format": "uuid",
          "type": "string"
        },
        "public_id": {
          "type": "string"
        },
        "type": {
          "const": "initialized",
          "type": "string"
        }
      },
      "required": [
        "type",
        "id",
        "party_id",
        "customer_type",
        "activity",
        "public_id",
        "level"
      ],
      "type": "object"
    },
    {
      "properties": {
        "activity": {
          "$ref": "#/$defs/Activity"
        },
        "type": {
          "const": "activity_updated",
          "type": "string"
        }
      },
      "required": [
        "type",
        "activity"
      ],
      "type": "object"
    },
    {
      "properties": {
        "status": {
          "$ref": "#/$defs/CustomerStatus"
        },
        "type": {
          "const": "frozen",
          "type": "string"
        }
      },
      "required": [
        "type",
        "status"
      ],
      "type": "object"
    },
    {
      "properties": {
        "status": {
          "$ref": "#/$defs/CustomerStatus"
        },
        "type": {
          "const": "unfrozen",
          "type": "string"
        }
      },
      "required": [
        "type",
        "status"
      ],
      "type": "object"
    },
    {
      "properties": {
        "status": {
          "$ref": "#/$defs/CustomerStatus"
        },
        "type": {
          "const": "closed",
          "type": "string"
        }
      },
      "required": [
        "type",
        "status"
      ],
      "type": "object"
    }
  ],
  "title": "CustomerEvent"
}
