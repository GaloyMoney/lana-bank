{
  "$defs": {
    "ReportRunState": {
      "enum": [
        "queued",
        "running",
        "success",
        "failed"
      ],
      "type": "string"
    },
    "ReportRunType": {
      "enum": [
        "scheduled",
        "manual"
      ],
      "type": "string"
    },
    "RequestedReport": {
      "properties": {
        "name": {
          "type": "string"
        },
        "norm": {
          "type": "string"
        },
        "report_definition_id": {
          "type": "string"
        }
      },
      "required": [
        "report_definition_id",
        "norm",
        "name"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "properties": {
        "external_id": {
          "type": "string"
        },
        "id": {
          "format": "uuid",
          "type": "string"
        },
        "requested_as_of_date": {
          "format": "date",
          "type": [
            "string",
            "null"
          ]
        },
        "requested_report": {
          "anyOf": [
            {
              "$ref": "#/$defs/RequestedReport"
            },
            {
              "type": "null"
            }
          ]
        },
        "run_type": {
          "$ref": "#/$defs/ReportRunType"
        },
        "start_time": {
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "$ref": "#/$defs/ReportRunState"
        },
        "type": {
          "const": "initialized",
          "type": "string"
        }
      },
      "required": [
        "type",
        "id",
        "external_id",
        "state",
        "run_type"
      ],
      "type": "object"
    },
    {
      "properties": {
        "requested_as_of_date": {
          "format": "date",
          "type": [
            "string",
            "null"
          ]
        },
        "requested_report": {
          "anyOf": [
            {
              "$ref": "#/$defs/RequestedReport"
            },
            {
              "type": "null"
            }
          ]
        },
        "run_type": {
          "$ref": "#/$defs/ReportRunType"
        },
        "start_time": {
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "$ref": "#/$defs/ReportRunState"
        },
        "type": {
          "const": "state_updated",
          "type": "string"
        }
      },
      "required": [
        "type",
        "state",
        "run_type"
      ],
      "type": "object"
    }
  ],
  "title": "ReportRunEvent"
}
