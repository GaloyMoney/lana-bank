{
  "$defs": {
    "Activity": {
      "enum": [
        "inactive",
        "active",
        "escheatable"
      ],
      "type": "string"
    },
    "DepositAccountLedgerAccountIds": {
      "properties": {
        "deposit_account_id": {
          "format": "uuid",
          "type": "string"
        },
        "frozen_deposit_account_id": {
          "format": "uuid",
          "type": "string"
        }
      },
      "required": [
        "deposit_account_id",
        "frozen_deposit_account_id"
      ],
      "type": "object"
    },
    "DepositAccountStatus": {
      "enum": [
        "active",
        "frozen",
        "closed"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "properties": {
        "account_holder_id": {
          "format": "uuid",
          "type": "string"
        },
        "account_ids": {
          "$ref": "#/$defs/DepositAccountLedgerAccountIds"
        },
        "activity": {
          "$ref": "#/$defs/Activity",
          "default": "active"
        },
        "currency": {
          "type": "string"
        },
        "id": {
          "format": "uuid",
          "type": "string"
        },
        "public_id": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/DepositAccountStatus"
        },
        "type": {
          "const": "initialized",
          "type": "string"
        }
      },
      "required": [
        "type",
        "id",
        "account_holder_id",
        "account_ids",
        "status",
        "public_id",
        "currency"
      ],
      "type": "object"
    },
    {
      "properties": {
        "activity": {
          "$ref": "#/$defs/Activity"
        },
        "type": {
          "const": "activity_updated",
          "type": "string"
        }
      },
      "required": [
        "type",
        "activity"
      ],
      "type": "object"
    },
    {
      "properties": {
        "status": {
          "$ref": "#/$defs/DepositAccountStatus"
        },
        "type": {
          "const": "frozen",
          "type": "string"
        }
      },
      "required": [
        "type",
        "status"
      ],
      "type": "object"
    },
    {
      "properties": {
        "status": {
          "$ref": "#/$defs/DepositAccountStatus"
        },
        "type": {
          "const": "unfrozen",
          "type": "string"
        }
      },
      "required": [
        "type",
        "status"
      ],
      "type": "object"
    },
    {
      "properties": {
        "status": {
          "$ref": "#/$defs/DepositAccountStatus"
        },
        "type": {
          "const": "closed",
          "type": "string"
        }
      },
      "required": [
        "type",
        "status"
      ],
      "type": "object"
    }
  ],
  "title": "DepositAccountEvent"
}
