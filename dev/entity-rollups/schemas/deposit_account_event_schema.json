{
  "$defs": {
    "Activity": {
      "enum": [
        "inactive",
        "active",
        "escheatable"
      ],
      "type": "string"
    },
    "DepositAccountStatus": {
      "enum": [
        "active",
        "frozen",
        "closed"
      ],
      "type": "string"
    },
    "LedgerAccountPair": {
      "description": "A pair of CALA ledger accounts for a single currency: one active, one frozen.",
      "properties": {
        "active": {
          "format": "uuid",
          "type": "string"
        },
        "frozen": {
          "format": "uuid",
          "type": "string"
        }
      },
      "required": [
        "active",
        "frozen"
      ],
      "type": "object"
    },
    "RestrictedCurrencyMap": {
      "properties": {
        "allowed": {
          "items": {
            "$ref": "#/$defs/string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "inner": {
          "additionalProperties": {
            "$ref": "#/$defs/LedgerAccountPair"
          },
          "type": "object"
        }
      },
      "required": [
        "allowed",
        "inner"
      ],
      "type": "object"
    },
    "string": {
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "properties": {
        "account_holder_id": {
          "format": "uuid",
          "type": "string"
        },
        "account_ids": {
          "$ref": "#/$defs/RestrictedCurrencyMap"
        },
        "activity": {
          "$ref": "#/$defs/Activity",
          "default": "active"
        },
        "id": {
          "format": "uuid",
          "type": "string"
        },
        "public_id": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/DepositAccountStatus"
        },
        "type": {
          "const": "initialized",
          "type": "string"
        }
      },
      "required": [
        "type",
        "id",
        "account_holder_id",
        "account_ids",
        "status",
        "public_id"
      ],
      "type": "object"
    },
    {
      "properties": {
        "activity": {
          "$ref": "#/$defs/Activity"
        },
        "type": {
          "const": "activity_updated",
          "type": "string"
        }
      },
      "required": [
        "type",
        "activity"
      ],
      "type": "object"
    },
    {
      "properties": {
        "status": {
          "$ref": "#/$defs/DepositAccountStatus"
        },
        "type": {
          "const": "frozen",
          "type": "string"
        }
      },
      "required": [
        "type",
        "status"
      ],
      "type": "object"
    },
    {
      "properties": {
        "status": {
          "$ref": "#/$defs/DepositAccountStatus"
        },
        "type": {
          "const": "unfrozen",
          "type": "string"
        }
      },
      "required": [
        "type",
        "status"
      ],
      "type": "object"
    },
    {
      "properties": {
        "status": {
          "$ref": "#/$defs/DepositAccountStatus"
        },
        "type": {
          "const": "closed",
          "type": "string"
        }
      },
      "required": [
        "type",
        "status"
      ],
      "type": "object"
    }
  ],
  "title": "DepositAccountEvent"
}
