{
  "mcpServers": {
    "opentelemetry": {
      "command": "uvx",
      "args": ["--with", "opentelemetry-semantic-conventions-ai==0.4.13", "opentelemetry-mcp"],
      "env": {
        "BACKEND_TYPE": "jaeger",
        "BACKEND_URL": "http://localhost:16686"
      }
    },
    "honeycomb": {
      "type": "http",
      "url": "https://mcp.honeycomb.io/mcp"
    }
  }
}
