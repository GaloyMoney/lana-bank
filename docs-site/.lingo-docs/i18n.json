{
  "version": 1.4,
  "locale": {
    "source": "en",
    "targets": ["es"]
  },
  "buckets": {
    "markdown": {
      "include": [
        "[locale]/*.md",
        "[locale]/*/*.md",
        "[locale]/*/*/*.md"
      ],
      "exclude": [
        "[locale]/for-platform-engineers/functional-architecture.md"
      ]
    },
    "json": {
      "include": [
        "scripts/api-descriptions.[locale].json",
        "scripts/event-descriptions.[locale].json"
      ],
      "lockedKeys": ["_meta", "_meta.*"]
    }
  },
  "$schema": "https://lingo.dev/schema/i18n.json"
}
